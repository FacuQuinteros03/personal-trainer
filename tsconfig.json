{
  "compilerOptions": {
    "target": "es5", // Ajusta esto según tus necesidades
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/",
    ".next/types/**/*.ts"
  ], // Ajusta esto según la ubicación de tus archivos
  "exclude": [
    "node_modules"
  ]
}
